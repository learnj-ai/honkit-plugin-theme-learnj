{
  "title": "LearnJ Theme",
  "description": "Example book demonstrating the LearnJ HonKit theme",
  "author": "Shaaf, Syed (sshaaf)",
  "plugins": [
    "-theme-default",
    "-search",
    "lunr",
    "highlight",
    "fontsettings",
    "mermaid-md-adoc",
    "theme-learnj"
  ],
  "pluginsConfig": {
    "theme-learnj": {
      "logo": "https://raw.githubusercontent.com/learnj-ai/learnj/main/image.png",
      "logoText": "LearnJ Theme",
      "githubUrl": "https://github.com/learnj-ai/honkit-plugin-theme-learnj",
      "showLevel": false
    },
    "fontsettings": {
      "theme": "white",
      "family": "sans",
      "size": 2
    }
  },
  "links": {
    "sidebar": {
      "npm package": "https://www.npmjs.com/package/honkit-plugin-theme-learnj"
    }
  }
}
